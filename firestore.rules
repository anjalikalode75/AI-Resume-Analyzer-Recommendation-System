rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "anjalikalode75@gmail.com";
    }

    // User profiles: each user can read/write only their own doc.
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Resume metadata: owner-only read/write; admin can read all.
    match /resumes/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Analysis results: same ownership model.
    match /analysis/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
